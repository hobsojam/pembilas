{
  "nasalAssimilation": {
    "description": "Rules for me- and pe- prefix consonant changes",
    "rules": [
      { "startsWith": ["b", "f", "v"],       "prefix": "mem",  "dropInitial": false },
      { "startsWith": ["p"],                  "prefix": "mem",  "dropInitial": true  },
      { "startsWith": ["c", "j", "sy", "z"], "prefix": "men",  "dropInitial": false },
      { "startsWith": ["d"],                  "prefix": "men",  "dropInitial": false },
      { "startsWith": ["t"],                  "prefix": "men",  "dropInitial": true  },
      { "startsWith": ["g", "h"],             "prefix": "meng", "dropInitial": false },
      { "startsWith": ["kh"],                 "prefix": "meng", "dropInitial": false },
      { "startsWith": ["k"],                  "prefix": "meng", "dropInitial": true  },
      { "startsWith": ["a","e","i","o","u"],  "prefix": "meng", "dropInitial": false },
      { "startsWith": ["s"],                  "prefix": "meny", "dropInitial": true  },
      { "startsWith": ["l","m","n","r","w","y","ng","ny"], "prefix": "me", "dropInitial": false }
    ]
  },
  "groups": [
    { "id": "verb",     "label": "Verb forms"      },
    { "id": "noun",     "label": "Noun forms"      },
    { "id": "modifier", "label": "Modifiers"       }
  ],
  "affixes": [
    {
      "id": "me",
      "label": "me-",
      "type": "prefix",
      "group": "verb",
      "function": "Active verb (actor focus)",
      "notes": "Undergoes nasal assimilation. Most common verbal prefix.",
      "example": "tulis"
    },
    {
      "id": "di",
      "label": "di-",
      "type": "prefix",
      "group": "verb",
      "function": "Passive verb (patient focus)",
      "notes": "Pairs with me- as the passive counterpart.",
      "example": "tulis"
    },
    {
      "id": "ber",
      "label": "ber-",
      "type": "prefix",
      "group": "verb",
      "function": "Intransitive verb; to have or use something",
      "notes": "ber- + root starting with 'r' becomes be-",
      "example": "jalan"
    },
    {
      "id": "ter",
      "label": "ter-",
      "type": "prefix",
      "group": "verb",
      "function": "Accidental or stative passive",
      "notes": "Implies unintentional action or a resulting state. The stative form often reads as an adjective in English (e.g. tertulis = 'written'), but ter- is grammatically a verbal prefix in Indonesian. ter- + root starting with 'r' becomes te- (e.g. terasa, not terrasa).",
      "example": "tulis"
    },
    {
      "id": "me_kan",
      "label": "me-...-kan",
      "type": "circumfix",
      "group": "verb",
      "function": "Causative active verb",
      "notes": "",
      "example": "tulis"
    },
    {
      "id": "me_i",
      "label": "me-...-i",
      "type": "circumfix",
      "group": "verb",
      "function": "Directional or repeated active verb",
      "notes": "",
      "example": "tulis"
    },
    {
      "id": "ber_an",
      "label": "ber-...-an",
      "type": "circumfix",
      "group": "verb",
      "function": "Reciprocal action or plural action",
      "notes": "",
      "example": "kenal"
    },
    {
      "id": "pe",
      "label": "pe-",
      "type": "prefix",
      "group": "noun",
      "function": "Agent or instrument noun",
      "notes": "Follows the same nasal assimilation as me-",
      "example": "tulis"
    },
    {
      "id": "an",
      "label": "-an",
      "type": "suffix",
      "group": "noun",
      "function": "Result noun, instrument noun, or collective",
      "notes": "",
      "example": "tulis"
    },
    {
      "id": "pe_an",
      "label": "pe-...-an",
      "type": "circumfix",
      "group": "noun",
      "function": "Abstract noun or place noun",
      "notes": "",
      "example": "tulis"
    },
    {
      "id": "per_an",
      "label": "per-...-an",
      "type": "circumfix",
      "group": "noun",
      "function": "Abstract or collective noun (separate circumfix from pe-...-an)",
      "notes": "Does not undergo nasal assimilation like pe-...-an does -- it's a distinct circumfix, not an allomorph of it. Which roots take per-...-an vs pe-...-an is lexically determined, not predictable by a phonological rule, so it must be annotated per word. per- + root starting with 'r' becomes pe- (e.g. peresmian, not perresmian), mirroring ber-/ter-.",
      "example": "teman"
    },
    {
      "id": "ke_an",
      "label": "ke-...-an",
      "type": "circumfix",
      "group": "noun",
      "function": "Abstract noun or state noun",
      "notes": "",
      "example": "cantik"
    },
    {
      "id": "ke",
      "label": "ke-",
      "type": "prefix",
      "group": "modifier",
      "function": "Ordinal numbers; some nominals",
      "notes": "",
      "example": "dua"
    },
    {
      "id": "se",
      "label": "se-",
      "type": "prefix",
      "group": "modifier",
      "function": "One; same; as...as",
      "notes": "",
      "example": "besar"
    },
    {
      "id": "nya",
      "label": "-nya",
      "type": "suffix",
      "group": "modifier",
      "function": "Definiteness marker or nominaliser",
      "notes": "",
      "example": "besar"
    },
    {
      "id": "lah",
      "label": "-lah",
      "type": "suffix",
      "group": "modifier",
      "function": "Softens imperatives; adds emphasis",
      "notes": "",
      "example": "makan"
    },
    {
      "id": "kan",
      "label": "-kan",
      "type": "suffix",
      "group": "verb",
      "function": "Causative or benefactive (bare, without me-)",
      "notes": "Often seen in imperatives: tuliskan! (write it down!)"
    },
    {
      "id": "i",
      "label": "-i",
      "type": "suffix",
      "group": "verb",
      "function": "Locative or repeated action on object (bare, without me-)",
      "notes": "Often seen in imperatives: tulisi! (write on it!)"
    }
  ]
}
